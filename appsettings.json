{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CompilerConfig": {
    "Image": "oj",
    "Version": "4.0",
    "ProblemVolume": "problem_data",
    "SubmissionVolume": "submission_data",
    "TestCaseVolume": "test_case_data"
  },
  "WorkdirConfig": {
    "SubmissionDir": "/work",
    "ProblemDir": "problems",
    "TestCaseDir": "/test-case",
    "ScriptDir": "/scripts"
  },
  "Kafka": {
    "ProducerSettings": {
      "BootstrapServers": "localhost:9094"
    },
    "ConsumerSettings": {
      "BootstrapServers": "localhost:9094",
      "GroupId": "compiler-service-group"
    },
    "Topics": {
      "SubmissionTopic": "compiler.submission-topic.request",
      "ResultTopic": "compiler.submission-topic.response",
      "TestCaseGenerationRequestTopic": "compiler.test-case-generation.request",
      "TestCaseGenerationResponseTopic": "compiler.test-case-generation.response"
    }
  },
  "AWS": {
    "S3": {
      "AccessKey": "",
      "SecretKey": "",
      "Region": "us-east-1",
      "BucketName": "bnoj-problem",
      "TestCasePrefix": "test-cases",
      "ProblemPrefix": "problems"
    }
  }
}
